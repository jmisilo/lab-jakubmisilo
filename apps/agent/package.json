{
  "name": "@labjm/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "dev:server": "vercel dev --listen 2000 --yes",
    "dev": "mkdir -p logs && LOG_LEVEL=info AGENT_LOG_FILE=logs/agent.log tsup --watch --onSuccess \"node dist/app/tui/index.js\"",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "4.0.0-beta.74",
    "@ai-sdk/tui": "1.0.0-beta.18",
    "@chat-adapter/state-pg": "4.31.0",
    "@chat-adapter/telegram": "4.31.0",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/functions": "3.7.1",
    "ai": "7.0.0-beta.182",
    "ai-tokenizer": "^1.0.6",
    "chat": "4.31.0",
    "dedent": "1.7.2",
    "dotenv": "17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.25",
    "pg": "^8.22.0",
    "pino": "10.3.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "ai": "7.0.0-beta.182"
  },
  "devDependencies": {
    "@labjm/jest-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "24.x",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "jest": "30.4.2",
    "tsup": "^8.5.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "24.x"
  }
}
