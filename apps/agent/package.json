    "@neondatabase/serverless": "^1.1.0",
    "@vercel/functions": "3.7.1",
    "ai": "7.0.0-beta.182",
    "ai-tokenizer": "^1.0.6",
    "chat": "4.31.0",
    "dedent": "1.7.2",
    "dotenv": "17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.25",
    "pg": "^8.22.0",
    "pino": "10.3.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "ai": "7.0.0-beta.182"
  },
  "devDependencies": {
    "@types/node": "24.x",
