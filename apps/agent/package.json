{
  "name": "@labjm/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.mjs",
    "dev:server": "vercel dev --listen 2000 --yes",
    "dev": "mkdir -p logs && LOG_LEVEL=info AGENT_LOG_FILE=logs/agent.log tsup --watch --onSuccess \"node dist/app/tui/index.js\"",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "4.0.11",
    "@ai-sdk/tui": "1.0.19",
    "@chat-adapter/state-pg": "4.33.0",
    "@chat-adapter/telegram": "4.33.0",
    "@fontsource/inter": "^5.2.8",
    "@imessage-sdk/blooio": "^0.1.2",
    "@imessage-sdk/chat-adapter": "0.1.0-beta.3",
    "@imessage-sdk/photon": "^0.1.2",
    "@labjm/utilities": "workspace:*",
    "@message-ui/components": "^0.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@upstash/qstash": "^2.11.2",
    "@vercel/functions": "3.7.1",
    "ai": "7.0.19",
    "ai-tokenizer": "^1.0.6",
    "chat": "4.33.0",
    "dedent": "1.7.2",
    "dotenv": "17.4.2",
    "drizzle-orm": "^0.45.2",
    "heic-decode": "2.1.0",
    "hono": "4.12.25",
    "pg": "^8.22.0",
    "pino": "10.3.1",
    "react": "19.2.7",
    "satori": "^0.26.0",
    "sharp": "0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@labjm/eslint-config": "workspace:*",
    "@labjm/jest-config": "workspace:*",
    "@types/heic-decode": "2.0.0",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "tsup": "^8.5.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "24.x"
  }
}
