# Optional LangSmith observability (off locally; metadata-only by default)
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_ENDPOINT="https://eu.api.smith.langchain.com"
LANGSMITH_PROJECT="labjm-agent-development"
