{
  "name": "@labjm/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "concurrently -k -n api-build,api-vercel -c blue,green \"tsup --watch\" \"sh scripts/dev-vercel.sh\"",
