    ".": "./src/index.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "4.0.0-beta.67",
    "@ai-sdk/google": "4.0.0-beta.83",
    "@ai-sdk/openai": "4.0.0-beta.74",
    "@hono/node-server": "2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "@labjm/ai": "workspace:^",
    "@labjm/schemas": "workspace:^",
    "@labjm/types": "workspace:^",
    "ai": "7.0.0-beta.182",
    "hono": "4.12.25"
  },
  "devDependencies": {
    "@labjm/eslint-config": "workspace:*",
    "@labjm/jest-config": "workspace:*",
    "@labjm/typescript-config": "workspace:*",
    "concurrently": "^10.0.3",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "tsup": "^8.5.1",
    "typescript": "6.0.3"
  }
