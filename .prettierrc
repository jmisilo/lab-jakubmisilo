{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "plugins": ["@ianvs/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
  "importOrder": [
    "<TYPES>",
    "",
    "<BUILTIN_MODULES>",
    "",
    "<THIRD_PARTY_MODULES>",
    "",
    "<TYPES>^(@labjm)",
    "^(@labjm)(/.*)$",
    "",
    "^(@/)(.*)$",
    "",
    "<TYPES>^[.]",
    "^[.]"
  ],
  "importOrderTypeScriptVersion": "6.0.0"
}
